{
    "name": "newline",
    "displayName": "NewLine",
    "description": "Whenever you save a file, this extension will automatically add a blank line at its end, if there isn't one already. If you have multiple blank lines, only one will be kept.",
    "version": "0.0.0",
    "author": {
        "name": "Chang Feng"
    },
    "publisher": "chang196700",
    "license": "MIT",
    "homepage": "https://github.com/chang196700/newline",
    "repository": {
        "type": "git",
        "url": "https://github.com/chang196700/newline.git"
    },
    "bugs": {
        "url": "https://github.com/chang196700/newline/issues"
    },
    "engines": {
        "vscode": "^1.44.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onCommand:newline.checkNewline",
        "onCommand:workbench.action.files.save"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "newline.checkNewline",
                "title": "NewLine: Check Newline"
            }
        ],
        "configuration": {
            "title": "object",
            "properties": {
                "newline.ignoreOnlyNewlinesFile": {
                    "type": "boolean",
                    "default": true,
                    "description": "Ignore files only have newlines."
                },
                "newline.fileExtensionsToIgnore": {
                    "type": "array",
                    "items": {
                        "allOf": [
                            {
                                "type": "string"
                            }
                        ]
                    },
                    "default": [
                        ".conf",
                        ".json",
                        ".liquid"
                    ],
                    "description": "List of file extensions to which blank lines should not be added."
                },
                "newline.fileRegexToIgnore": {
                    "type": "array",
                    "items": {
                        "anyOf": [
                            {
                                "type": "object",
                                "properties": {
                                    "type": {
                                        "type": "string",
                                        "default": "basename",
                                        "enum": [
                                            "basename",
                                            "fullName"
                                        ],
                                        "enumDescriptions": [
                                            "Only basename of file",
                                            "Filename with full path"
                                        ]
                                    },
                                    "regex": {
                                        "type": "string",
                                        "minLength": 1
                                    }
                                }
                            }
                        ]
                    },
                    "description": "Ignore files match regex."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "yarn run compile",
        "compile": "tsc -p ./",
        "lint": "eslint src",
        "watch": "tsc -watch -p ./",
        "pretest": "yarn run compile && yarn run lint",
        "test": "node ./out/test/runTest.js",
        "deploy": "vsce publish --yarn"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.9",
        "@types/node": "^20.17.0",
        "@types/vscode": "^1.44.0",
        "@typescript-eslint/eslint-plugin": "^8.26.0",
        "@typescript-eslint/parser": "^8.26.0",
        "@vscode/test-electron": "^2.4.1",
        "@vscode/vsce": "^3.2.1",
        "eslint": "^9.22.0",
        "glob": "^13.0.6",
        "mocha": "^10.7.3",
        "typescript": "^5.6.3"
    },
    "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
