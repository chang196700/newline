{
    "name": "newline",
    "displayName": "NewLine",
    "description": "Whenever you save a file, this extension will automatically add a blank line at its end, if there isn't one already. If you have multiple blank lines, only one will be kept.",
    "version": "0.0.0",
    "author": {
        "name": "Chang Feng"
    },
    "publisher": "chang196700",
    "license": "MIT",
    "homepage": "https://github.com/chang196700/newline",
    "repository": {
        "type": "git",
        "url": "https://github.com/chang196700/newline.git"
    },
    "bugs": {
        "url": "https://github.com/chang196700/newline/issues"
    },
    "engines": {
        "vscode": "^1.30.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onCommand:newline.checkNewline",
        "onCommand:workbench.action.files.save"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "newline.checkNewline",
                "title": "NewLine: Check Newline"
            }
        ],
        "configuration": {
            "title": "object",
            "properties": {
                "newline.ignoreOnlyNewlinesFile": {
                    "type": "boolean",
                    "default": true,
                    "description": "Ignore files only have newlines."
                },
                "newline.fileExtensionsToIgnore": {
                    "type": "array",
                    "items": {
                        "allOf": [
                            {
                                "type": "string"
                            }
                        ]
                    },
                    "default": [
                        ".conf",
                        ".json",
                        ".liquid"
                    ],
                    "description": "List of file extensions to which blank lines should not be added."
                },
                "newline.fileRegexToIgnore": {
                    "type": "array",
                    "items": {
                        "anyOf": [
                            {
                                "type": "object",
                                "properties": {
                                    "type": {
                                        "type": "string",
                                        "default": "basename",
                                        "enum": [
                                            "basename",
                                            "fullName"
                                        ],
                                        "enumDescriptions": [
                                            "Only basename of file",
                                            "Filename with full path"
                                        ]
                                    },
                                    "regex": {
                                        "type": "string",
                                        "minLength": 1
                                    }
                                }
                            }
                        ]
                    },
                    "description": "Ignore files match regex."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "pnpm run compile",
        "compile": "tsc -p ./",
        "lint": "eslint src",
        "watch": "tsc -watch -p ./",
        "package": "vsce package --no-dependencies -o dist/",
        "release:dry-run": "semantic-release --dry-run"
    },
    "devDependencies": {
        "@semantic-release/changelog": "6.0.3",
        "@semantic-release/exec": "7.1.0",
        "@semantic-release/github": "12.0.6",
        "@semantic-release/npm": "13.1.5",
        "@types/node": "20.19.39",
        "@types/vscode": "1.30.0",
        "@typescript-eslint/eslint-plugin": "8.59.2",
        "@typescript-eslint/parser": "8.59.2",
        "@vscode/vsce": "3.9.1",
        "eslint": "9.39.4",
        "semantic-release": "25.0.3",
        "typescript": "5.9.3"
    },
    "packageManager": "pnpm@11.0.8+sha512.4c4097e1dd2d42372c4e7fa5a791ff28fc75a484c7ac192e64b1df0fdef17594ba982f9b4fed9adfb3c757846f565b799b2763fb3733d1de1bcb82cf46684912"
}
